# ═══════════════════════════════════════════════════════
#  Telegram API (получить на https://my.telegram.org)
# ═══════════════════════════════════════════════════════
API_ID=12345678
API_HASH=your_api_hash_here

# Имя файла сессии Telegram (без расширения)
PYROGRAM_SESSION=openclaw_userbot

# ═══════════════════════════════════════════════════════
#  Telethon Bridge
# ═══════════════════════════════════════════════════════
# TELETHON_SESSION_NAME=openclaw_userbot_telethon
# TELETHON_STRING_SESSION=            # строковая сессия (альтернатива файловой)
# TELETHON_DEVICE_MODEL=OpenClaw Telethon Bridge
# TELETHON_SYSTEM_VERSION=Unknown
# TELETHON_APP_VERSION=0.1
# TELETHON_LANG_CODE=ru
# TELETHON_SYSTEM_LANG_CODE=ru-RU

# ═══════════════════════════════════════════════════════
#  LLM — платная модель с tool calling (OpenRouter / DeepSeek / OpenAI / Groq)
# ═══════════════════════════════════════════════════════
LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=sk-or-v1-your_openrouter_key_here
LLM_MODEL=deepseek/deepseek-chat-v3-0324

# ═══════════════════════════════════════════════════════
#  OpenClaw — бесплатная модель для разговоров (без tool calling)
#  Если не указан, все запросы пойдут через платную LLM
# ═══════════════════════════════════════════════════════
OPENCLAW_URL=http://127.0.0.1:18789/v1/chat/completions
OPENCLAW_TOKEN=your_openclaw_gateway_token
OPENCLAW_MODEL=openclaw:main

# ═══════════════════════════════════════════════════════
#  Поведение бота
# ═══════════════════════════════════════════════════════
# Триггер для вызова бота в групповых чатах
GROUP_TRIGGER=Арсений

# Максимум циклов tool-calling за один запрос
MAX_TOOL_CALLS=12

# Бэкенд транспорта: telethon или pyrogram
BOT_RUNTIME=telethon

# Разрешённые чаты (через запятую). Пусто = все чаты разрешены
ALLOWED_CHAT_IDS=

# ID главного форум-чата (supergroup с топиками)
MAIN_FORUM_CHAT_ID=

# ═══════════════════════════════════════════════════════
#  Безопасность и роли
# ═══════════════════════════════════════════════════════
# Telegram user ID админов (через запятую) — полный доступ ко всем tools
ADMIN_USER_IDS=

# Разрешённые пользователи (через запятую). Пусто = все разрешены
ALLOWED_USER_IDS=

# Заблокированные пользователи (через запятую)
BLOCKED_USER_IDS=

# ═══════════════════════════════════════════════════════
#  База данных
# ═══════════════════════════════════════════════════════
BOT_DB_PATH=bot.db
BOT_TIMEZONE=Europe/Moscow
